# Copy this file to .env and fill in the real values.
# Never commit .env or tunnel credentials to git.

# Cloudflare Tunnel token copied from Zero Trust > Networks > Tunnels.
TUNNEL_TOKEN=replace-with-your-cloudflare-tunnel-token

# Java backend runtime configuration.
DB_HOST=replace-with-postgres-host
DB_PORT=5432
DB_NAME=replace-with-database-name
DB_USER=replace-with-database-user
DB_PASSWORD=replace-with-database-password
JWT_SECRET=replace-with-long-random-secret
