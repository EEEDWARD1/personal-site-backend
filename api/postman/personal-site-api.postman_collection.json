  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Run first. Copy preAuthToken from the response into the collection variable if needed."
          }
        },
        {
          "name": "Verify TOTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preAuthToken\": \"{{preAuthToken}}\",\n  \"code\": \"<MANUAL_TOTP_CODE>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/totp/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "totp",
                "verify"
              ]
            },
            "description": "Replace <MANUAL_TOTP_CODE> with the current 6-digit code. Copy token from the response into the jwt collection variable."
          }
        }
      ]
    },
